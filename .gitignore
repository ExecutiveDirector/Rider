# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# ─────────────────────────────────────────────────────────────────────────
# Signing — NEVER commit these. See android/app/build.gradle.kts: it reads
# key.properties + the keystore path from it if present, falling back to
# debug signing if not. CI reconstructs both from GitHub secrets at build
# time (see .github/workflows/firebase-distribute.yml) — they never need
# to touch the repo at all.
# ─────────────────────────────────────────────────────────────────────────
android/key.properties
android/app/keystore/
*.jks
*.keystore

# NOTE: google-services.json is intentionally NOT ignored — it needs to
# be present in the repo for CI to build at all (unlike the keystore
# below, it's just Firebase project/client identifiers, not a secret key,
# and this matches how the vendor app already handles it).

# Local build config
android/local.properties